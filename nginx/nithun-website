# Redirect nithunmanoharan.com to nithun.no
server {
    listen 80;
    listen 443 ssl;
    server_name nithunmanoharan.com www.nithunmanoharan.com;

    ssl_certificate /etc/letsencrypt/live/nithunmanoharan.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nithunmanoharan.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://nithun.no$request_uri;
}

# Primary domain: nithun.no
server {
    listen 80;
    server_name nithun.no www.nithun.no;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name nithun.no www.nithun.no;
    root /var/www/nithun-website/dist;
    index index.html;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://covers.openlibrary.org https://books.google.com; connect-src 'self' https://www.googleapis.com; frame-ancestors 'none'" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    ssl_certificate /etc/letsencrypt/live/nithun.no/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nithun.no/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # OCSP Stapling - speeds up handshakes and improves privacy
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/letsencrypt/live/nithun.no/chain.pem;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;
}
